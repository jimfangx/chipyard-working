      "string": "make tracegen CONFIG=BoomV4TraceGenConfig"
    }
  ],
  "chipyard-cva6": [
    {
      "custom": true,
      "string": "if ! git -C \"$LOCAL_CHIPYARD_DIR/generators/cva6\" rev-parse --is-inside-work-tree >/dev/null 2>&1; then git -C \"$LOCAL_CHIPYARD_DIR\" submodule update --init generators/cva6; fi && git -C \"$LOCAL_CHIPYARD_DIR/generators/cva6\" submodule update --init src/main/resources/cva6/vsrc/cva6 && make run-binary-fast CONFIG=CVA6Config BINARY=$RISCV/riscv64-unknown-elf/share/riscv-tests/benchmarks/multiply.riscv"
    }
  ],
  "chipyard-ibex": [
    {
      "custom": true,
      "string": "true"
    }
  ],
  "chipyard-vexiiriscv": [
    {
      "custom": true,
